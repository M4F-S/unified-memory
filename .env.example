# ============================================================
# UnifiedMemory — Environment Variables
# Copy this file to .env and fill in all values
# NEVER commit .env to git
# ============================================================

# ── LLM (OpenRouter — ALL AI calls go here) ─────────────────
OPENROUTER_API_KEY=sk-or-v1-YOUR_KEY_HERE
# Classification model (cheap + fast): $0.14/M input
OPENROUTER_CLASSIFY_MODEL=deepseek/deepseek-v3.2
# Agent reasoning model (smart + balanced): $0.45/M input
OPENROUTER_SMART_MODEL=kimi/kimi-k2.5
# Embedding (via OpenRouter passthrough to OpenAI)
OPENROUTER_EMBED_MODEL=openai/text-embedding-3-small

# ── NEAR Blockchain ──────────────────────────────────────────
NEAR_ACCOUNT_ID=your-account.testnet
NEAR_PRIVATE_KEY=ed25519:YOUR_PRIVATE_KEY_HERE
NEAR_CONTRACT_ID=unified-memory.testnet
NEAR_NETWORK=testnet
NEAR_RPC=https://rpc.testnet.near.org

# ── Pinecone Vector Store ────────────────────────────────────
PINECONE_API_KEY=YOUR_PINECONE_KEY
PINECONE_INDEX_NAME=unified-memory
PINECONE_ENV=gcp-starter
# Get PINECONE_HOST from Pinecone console → your index → "Host" field
PINECONE_HOST=unified-memory-REPLACE.svc.gcp-starter.pinecone.io

# ── Circle (x402 USDC Payments) ──────────────────────────────
CIRCLE_API_KEY=YOUR_CIRCLE_KEY
CIRCLE_WALLET_ADDRESS=0xYOUR_WALLET_ADDRESS
CIRCLE_WALLET_ID=YOUR_WALLET_ID
CIRCLE_ENTITY_SECRET=YOUR_ENTITY_SECRET

# ── Cloudflare Workers ───────────────────────────────────────
CLOUDFLARE_ACCOUNT_ID=YOUR_CF_ACCOUNT_ID
CLOUDFLARE_API_TOKEN=YOUR_CF_TOKEN
MCP_URL=https://unified-memory-mcp.YOUR-SUBDOMAIN.workers.dev

# ── Demo Config ───────────────────────────────────────────────
DEMO_CONSENT_TOKEN=0

# ── Platform OAuth (add as you connect platforms) ────────────
GITHUB_TOKEN=ghp_YOUR_TOKEN
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
SPOTIFY_CLIENT_ID=YOUR_SPOTIFY_CLIENT_ID
SPOTIFY_CLIENT_SECRET=YOUR_SPOTIFY_CLIENT_SECRET
NOTION_API_KEY=secret_YOUR_NOTION_KEY
SLACK_BOT_TOKEN=xoxb-YOUR_SLACK_TOKEN
DISCORD_BOT_TOKEN=YOUR_DISCORD_TOKEN
REDDIT_CLIENT_ID=YOUR_REDDIT_CLIENT_ID
REDDIT_CLIENT_SECRET=YOUR_REDDIT_CLIENT_SECRET
TWITTER_BEARER_TOKEN=YOUR_TWITTER_BEARER_TOKEN
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_TOKEN
