  {
    "title": "Debugging a Python asyncio deadlock",
    "create_time": 1746201600.0,
    "update_time": 1746205200.0,
    "mapping": {
      "node-0": {
        "id": "node-0",
        "message": { "id": "m0", "author": { "role": "system" }, "content": { "content_type": "text", "parts": [""] } },
        "parent": null,
        "children": ["node-1"]
      },
      "node-1": {
        "id": "node-1",
        "message": { "id": "m1", "author": { "role": "user" }, "create_time": 1746201610.0, "content": { "content_type": "text", "parts": ["My FastAPI app hangs when I call an async function from inside a sync route via asyncio.run(). Why does this deadlock?"] } },
        "parent": "node-0",
        "children": ["node-2"]
      },
      "node-2": {
        "id": "node-2",
        "message": { "id": "m2", "author": { "role": "assistant" }, "create_time": 1746201660.0, "content": { "content_type": "text", "parts": ["You're nesting event loops. FastAPI already runs inside an event loop, so asyncio.run() tries to start a second one..."] } },
        "parent": "node-1",
        "children": ["node-3"]
      },
      "node-3": {
        "id": "node-3",
        "message": { "id": "m3", "author": { "role": "user" }, "create_time": 1746201800.0, "content": { "content_type": "text", "parts": ["Got it — I switched to run_in_threadpool for the blocking call and it works now. Thanks!"] } },
        "parent": "node-2",
        "children": []
      }
    }
  },
