# Sophia Shopper — Caddy Reverse Proxy Configuration
#
# Replace {$DOMAIN} with your actual domain when ready.
# Until domain is registered, use :80 for local/IP access.
#
# Usage:
#   With domain:  DOMAIN=mysophia.tech docker compose up
#   Without:      docker compose up  (serves on port 80)

{$DOMAIN:localhost} {
	# Landing page — Next.js static export lives in out/
	root * /srv/landing/out
	file_server

	# Try .html extension for clean URLs (/privacy → /privacy.html)
	try_files {path} {path}.html {path}/index.html
}

api.{$DOMAIN:localhost} {
	# API reverse proxy
	reverse_proxy sophia-api:3100

	# Security headers
	header {
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		-Server
	}
}

unified-memory.kawai-labs.com {
	# UnifiedMemory hackathon frontend
	reverse_proxy 172.17.0.1:3001

	# Security headers
	header {
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		-Server
	}
}
