{
  "name": "unified-memory",
  "version": "1.0.0",
  "description": "Unified memory OS for AI agents — AI Agents Berlin Hackathon 2026",
  "scripts": {
    "dev": "cd app && npm run dev",
    "deploy:workers": "cd workers && wrangler deploy",
    "deploy:contract": "cd contracts && near dev-deploy",
    "demo": "python demo/agent.py",
    "load-demo-data": "python -c \"from ingestion.synthesis import load_demo_memories; load_demo_memories()\""
  },
  "workspaces": ["app", "contracts", "workers"],
  "dependencies": {
    "near-sdk-js": "^1.0.0",
    "hono": "^4.0.0",
    "@near-wallet-selector/core": "^8.0.0",
    "@near-wallet-selector/my-near-wallet": "^8.0.0",
    "next": "14.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  }
}
